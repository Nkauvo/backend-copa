{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ],
  "env": {
    "SUPABASE_URL": "https://seu-projeto.supabase.co",
    "SUPABASE_ANON_KEY": "sua-chave-anon-aqui"
  }
}